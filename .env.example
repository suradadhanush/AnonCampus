# ─────────────────────────────────────────────────────────────
#  AnonCampus — Environment Variables Template
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Async URL used by FastAPI (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://anoncampus:change_me@postgres:5432/anoncampus

# Sync URL used by Celery workers (psycopg2 driver)
SYNC_DATABASE_URL=postgresql://anoncampus:change_me@postgres:5432/anoncampus

# PostgreSQL container password — must match above
POSTGRES_PASSWORD=change_me

# ── Redis ─────────────────────────────────────────────────────
# Used for: Celery broker/backend, rate limiting, distributed locks
REDIS_URL=redis://redis:6379/0

# ── Security ──────────────────────────────────────────────────
# JWT signing key — MUST be at least 32 random characters
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_long_random_secret_minimum_32_chars

# JWT algorithm — do not change unless you know what you are doing
ALGORITHM=HS256

# Access token lifetime in minutes (15 recommended)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Application ───────────────────────────────────────────────
# Options: development | production
# production: disables docs, seeding, uses WARNING logs, strict CORS
ENVIRONMENT=development

# Allowed frontend origins — comma-separated in production
# Example production: ALLOWED_ORIGINS=["https://app.yourdomain.com"]
ALLOWED_ORIGINS=["http://localhost:3000"]
